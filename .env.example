# GDC Vault 자격 증명 (선택) — CLI로 직접 로그인할 때 사용
GDC_USERNAME=
GDC_PASSWORD=

# Claude API — 챕터/용어집/핵심 포인트 생성에 필수
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity API — 해외 게임 언론 기사 검색에 필수 (없어도 나머지는 동작)
PERPLEXITY_API_KEY=pplx-...

# 모델 ID (생략 시 기본값 사용)
# Claude 옵션: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
# Perplexity 옵션: sonar, sonar-pro, sonar-reasoning
AI_MODEL=claude-sonnet-4-6
PERPLEXITY_MODEL=sonar-pro

# 기능 on/off 플래그 (true/false)
AI_ENHANCE_ENABLED=true
WEB_CONTEXT_ENABLED=true

# 품질 개선 토글
# AI_NORMALIZE_ENABLED: 챕터/용어집/핵심포인트/Q&A 병렬 생성 후 고유명사 철자를
#   순차 1회 호출로 통일 (세션당 ~$0.01 추가, 3~5초 지연). 파일 간 일관성 확보용.
AI_NORMALIZE_ENABLED=true
# AI_QA_ENABLED: 청중 Q&A 섹션을 qa.md 로 별도 추출
AI_QA_ENABLED=true

# 관련 기사 검색 튜닝
# WEB_CONTEXT_MAX_QUERIES: 세션당 Perplexity 호출 수 상한 (기본값은 세션 + 발표자 + 엔티티 팬아웃 3)
WEB_CONTEXT_MAX_QUERIES=5
# WEB_CONTEXT_WIDEN_IF_FEWER: 1차 검색 결과가 이 수 미만이면 도메인 필터 제거하고 재시도
WEB_CONTEXT_WIDEN_IF_FEWER=3
